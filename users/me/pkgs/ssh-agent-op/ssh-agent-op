#!/usr/bin/env bash
#
# ssh-agent-op — pin a per-repo SSH public key based on git user.name
#
# For repos with a github.com remote, fetches the public keys from
# https://github.com/<user.name>.keys and writes a per-repo
# `core.sshCommand = ssh -i <pubkey> -o IdentitiesOnly=yes` entry
# into ~/.gitconfig.autossh (never touches ~/.gitconfig itself).
#
# With IdentitiesOnly + an explicit pubkey, the 1Password SSH agent
# is asked to sign only with the matching private key — no race, no
# "too many authentication failures", no wrong-user auth.

set -euo pipefail

: "${AUTOSSH_CONFIG:=$HOME/.gitconfig.autossh}"
: "${AUTOSSH_STATE_DIR:=$HOME/.local/state/ssh-agent-op}"
: "${AUTOSSH_KEYS_DIR:=$HOME/.ssh/ssh-agent-op}"
: "${AUTOSSH_TTL_SECONDS:=86400}"  # re-fetch keys after 24h with --if-needed

QUIET=0

log()  { (( QUIET )) || printf '%s\n' "$*"; }
err()  { printf 'ssh-agent-op: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }

usage() {
    cat <<'EOF'
Usage: ssh-agent-op <command> [args]

Per-repo (inside a git repo):
    apply [--if-needed] [--quiet]
        Configure the current repo to use the keys from
        https://github.com/<user.name>.keys. Idempotent.

        --if-needed   Exit silently if: not a repo, no github.com remote,
                      no user.name, or cache is still fresh.
        --quiet       Suppress non-error output.

    list
        Show registered repos and their GitHub user.

    remove <path>
        Remove the registration for a repo.

Per-directory (outside any repo, e.g. a "projects" parent dir):
    pin <dir> <github-user>
        Pin a directory tree to a GitHub user's keys. The shell hook
        will export GIT_SSH_COMMAND when cwd is inside <dir> and not
        already in a repo, so plain `git clone` uses the right key.

    unpin <dir>
        Remove a directory pin.

    pins
        Show pinned directories and their GitHub user.

    resolve [<cwd>]
        Print the GIT_SSH_COMMAND value for the closest pinned ancestor
        of <cwd> (default: $PWD), or nothing. Used by the shell hook.

Shell integration:
    shell-init
        Emit a zsh/bash chpwd hook. In a repo: runs `apply --if-needed`
        and unsets GIT_SSH_COMMAND. Outside a repo: exports
        GIT_SSH_COMMAND from `resolve`, or unsets it. Add to your
        ~/.zshrc via:
            eval "$(ssh-agent-op shell-init)"
EOF
}

# ---------- helpers ----------

_path_hash() {
    # 12-char hash of a path, used to name per-repo config/state files.
    printf '%s' "$1" | sha1sum | awk '{print substr($1, 1, 12)}'
}

_is_valid_github_username() {
    # GitHub usernames: alphanumeric or hyphen, can't start/end with hyphen,
    # max 39 chars. Rejects "First Last" or email-style user.name values.
    [[ "$1" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,37}[A-Za-z0-9])?$ ]]
}

_has_github_remote() {
    local url
    while read -r _ url _; do
        [[ "$url" == *github.com:* || "$url" == *github.com/* ]] && return 0
    done < <(git -C "$1" remote -v 2>/dev/null)
    return 1
}

_cache_fresh() {
    # Returns 0 if state file exists, records the same user, and is younger
    # than AUTOSSH_TTL_SECONDS. Used by --if-needed to skip re-fetching.
    local state_file=$1 user=$2
    [[ -f "$state_file" ]] || return 1
    local cached_user cached_updated now
    cached_user=$(awk -F= '/^user=/{print $2; exit}' "$state_file")
    cached_updated=$(awk -F= '/^updated=/{print $2; exit}' "$state_file")
    [[ "$cached_user" == "$user" ]] || return 1
    now=$(date +%s)
    (( now - ${cached_updated:-0} < AUTOSSH_TTL_SECONDS ))
}

_fetch_user_keys() {
    # Download <github-user>'s public keys to $AUTOSSH_KEYS_DIR/<user>/key_*.pub.
    # Stale key files from a prior fetch are removed first so that a key
    # rotated away on GitHub no longer lingers locally.
    local user=$1
    _is_valid_github_username "$user" \
        || die "invalid github username: $user"

    log "ssh-agent-op: fetching https://github.com/$user.keys"
    local keys_raw
    if ! keys_raw=$(curl -fsSL --max-time 10 "https://github.com/$user.keys"); then
        die "failed to fetch https://github.com/$user.keys (network error or user not found)"
    fi
    [[ -n "$keys_raw" ]] || die "no public keys published at github.com/$user"

    local user_keys_dir="$AUTOSSH_KEYS_DIR/$user"
    mkdir -p "$user_keys_dir"
    chmod 700 "$AUTOSSH_KEYS_DIR" "$user_keys_dir"
    find "$user_keys_dir" -maxdepth 1 -name 'key_*.pub' -delete 2>/dev/null || true

    local i=0 line
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        if ! printf '%s\n' "$line" | ssh-keygen -lf - >/dev/null 2>&1; then
            err "skipping invalid key line $((i+1)) for $user"
            continue
        fi
        local key_file="$user_keys_dir/key_${i}.pub"
        printf '%s\n' "$line" > "$key_file"
        chmod 644 "$key_file"
        i=$((i + 1))
    done <<< "$keys_raw"

    (( i > 0 )) || die "no valid public keys parsed for $user"
}

_count_user_keys() {
    local user=$1
    find "$AUTOSSH_KEYS_DIR/$user" -maxdepth 1 -name 'key_*.pub' 2>/dev/null | wc -l
}

_build_ssh_cmd() {
    # Print the `core.sshCommand` value for <github-user>; return 1 if no
    # keys are cached on disk for them.
    local user=$1
    local user_keys_dir="$AUTOSSH_KEYS_DIR/$user"
    local cmd='ssh -o IdentitiesOnly=yes'
    local f had=0
    for f in "$user_keys_dir"/key_*.pub; do
        [[ -f "$f" ]] || continue
        cmd+=" -i \"$f\""
        had=1
    done
    (( had )) || return 1
    printf '%s\n' "$cmd"
}

# ---------- apply ----------

cmd_apply() {
    local if_needed=0
    while [[ $# -gt 0 ]]; do
        case $1 in
            --if-needed) if_needed=1 ;;
            --quiet)     QUIET=1 ;;
            -h|--help)   usage; return 0 ;;
            *)           die "apply: unknown flag: $1" ;;
        esac
        shift
    done

    # Resolve repo root. With --if-needed, silently skip non-repos.
    local toplevel
    if ! toplevel=$(git rev-parse --show-toplevel 2>/dev/null); then
        (( if_needed )) && return 0
        die "not in a git repository"
    fi

    if ! _has_github_remote "$toplevel"; then
        (( if_needed )) && return 0
        die "no github.com remote in $toplevel"
    fi

    local user
    user=$(git -C "$toplevel" config user.name 2>/dev/null || true)
    if [[ -z "$user" ]]; then
        (( if_needed )) && return 0
        die "user.name is not set for $toplevel (try: git config user.name <github-username>)"
    fi

    if ! _is_valid_github_username "$user"; then
        (( if_needed )) && return 0
        die "user.name '$user' is not a valid GitHub username (must be alphanumeric/hyphen, <=39 chars)"
    fi

    local state_file="$AUTOSSH_STATE_DIR/repos/$(_path_hash "$toplevel")"
    if (( if_needed )) && _cache_fresh "$state_file" "$user"; then
        return 0
    fi

    _fetch_user_keys "$user"

    local ssh_cmd
    ssh_cmd=$(_build_ssh_cmd "$user") \
        || die "no keys cached for $user"

    # Write the per-repo gitconfig fragment that ~/.gitconfig.autossh will
    # include conditionally.
    local repo_conf_dir="$AUTOSSH_STATE_DIR/configs"
    local repo_conf="$repo_conf_dir/$(_path_hash "$toplevel").gitconfig"
    mkdir -p "$repo_conf_dir"
    cat > "$repo_conf" <<EOF
# managed by ssh-agent-op — do not edit
# repo:    $toplevel
# user:    $user
# updated: $(date -Iseconds)
[core]
    sshCommand = $ssh_cmd
EOF

    # Register/refresh the includeIf entry in ~/.gitconfig.autossh.
    # Uses `git config --file` so we never hand-edit INI.
    mkdir -p "$(dirname "$AUTOSSH_CONFIG")"
    [[ -f "$AUTOSSH_CONFIG" ]] || : > "$AUTOSSH_CONFIG"
    local section="includeIf.gitdir:$toplevel/"
    git config --file "$AUTOSSH_CONFIG" --remove-section "$section" 2>/dev/null || true
    git config --file "$AUTOSSH_CONFIG" "$section.path" "$repo_conf"

    # Update the cache so --if-needed short-circuits next time.
    mkdir -p "$(dirname "$state_file")"
    {
        printf 'user=%s\n' "$user"
        printf 'updated=%s\n' "$(date +%s)"
        printf 'repo_conf=%s\n' "$repo_conf"
    } > "$state_file"

    log "ssh-agent-op: $toplevel → github.com/$user ($(_count_user_keys "$user") key(s))"
}

# ---------- list ----------

cmd_list() {
    [[ -f "$AUTOSSH_CONFIG" ]] || return 0
    local key path dir user
    while read -r key path; do
        # git --get-regexp lowercases section names on output
        dir=${key#includeif.gitdir:}
        dir=${dir%.path}
        user=""
        [[ -f "$path" ]] && user=$(awk '/^# user:/{print $3; exit}' "$path")
        printf '%s\t%s\n' "${user:-?}" "$dir"
    done < <(git config --file "$AUTOSSH_CONFIG" --get-regexp '^includeIf\.gitdir:.*\.path$' 2>/dev/null || true)
}

# ---------- remove ----------

cmd_remove() {
    local target=${1:-}
    [[ -n "$target" ]] || die "usage: ssh-agent-op remove <path>"
    target=$(cd "$target" 2>/dev/null && pwd -P || printf '%s' "$target")
    [[ -f "$AUTOSSH_CONFIG" ]] || die "no registrations exist"
    local section="includeIf.gitdir:$target/"
    if git config --file "$AUTOSSH_CONFIG" --remove-section "$section" 2>/dev/null; then
        local state_file="$AUTOSSH_STATE_DIR/repos/$(_path_hash "$target")"
        rm -f "$state_file"
        log "removed $target"
    else
        die "no registration found for $target"
    fi
}

# ---------- pin / unpin / pins / resolve ----------

cmd_pin() {
    local dir=${1:-} user=${2:-}
    [[ -n "$dir" && -n "$user" ]] || die "usage: ssh-agent-op pin <dir> <github-user>"
    [[ -d "$dir" ]] || die "directory does not exist: $dir"
    _is_valid_github_username "$user" \
        || die "invalid github username: $user"

    local abs_dir
    abs_dir=$(cd "$dir" && pwd -P)

    if git -C "$abs_dir" rev-parse --show-toplevel >/dev/null 2>&1; then
        err "warning: $abs_dir is itself inside a git repo; the chpwd hook short-circuits to per-repo behavior there. You probably want 'apply'."
    fi

    _fetch_user_keys "$user"

    local pin_dir="$AUTOSSH_STATE_DIR/dirs"
    mkdir -p "$pin_dir"
    local pin_file="$pin_dir/$(_path_hash "$abs_dir")"
    {
        printf 'dir=%s\n' "$abs_dir"
        printf 'user=%s\n' "$user"
        printf 'updated=%s\n' "$(date +%s)"
    } > "$pin_file"

    log "ssh-agent-op: pinned $abs_dir → github.com/$user ($(_count_user_keys "$user") key(s))"
}

cmd_unpin() {
    local dir=${1:-}
    [[ -n "$dir" ]] || die "usage: ssh-agent-op unpin <dir>"
    local abs_dir
    abs_dir=$(cd "$dir" 2>/dev/null && pwd -P) || abs_dir=$dir
    local pin_file="$AUTOSSH_STATE_DIR/dirs/$(_path_hash "$abs_dir")"
    [[ -f "$pin_file" ]] || die "no pin found for $abs_dir"
    rm -f "$pin_file"
    log "ssh-agent-op: unpinned $abs_dir"
}

cmd_pins() {
    local pin_dir="$AUTOSSH_STATE_DIR/dirs"
    [[ -d "$pin_dir" ]] || return 0
    local f dir user
    for f in "$pin_dir"/*; do
        [[ -f "$f" ]] || continue
        dir=$(awk -F= '/^dir=/{print $2; exit}' "$f")
        user=$(awk -F= '/^user=/{print $2; exit}' "$f")
        printf '%s\t%s\n' "${user:-?}" "${dir:-?}"
    done
}

cmd_resolve() {
    # Walk up from <cwd> looking for a pinned ancestor. If found, print the
    # sshCommand for that user. Silent + exit 0 if no pin matches.
    local cwd=${1:-$PWD}
    cwd=$(cd "$cwd" 2>/dev/null && pwd -P) || return 0

    local d=$cwd pin_file user
    while [[ -n "$d" ]]; do
        pin_file="$AUTOSSH_STATE_DIR/dirs/$(_path_hash "$d")"
        if [[ -f "$pin_file" ]]; then
            user=$(awk -F= '/^user=/{print $2; exit}' "$pin_file")
            [[ -n "$user" ]] && _build_ssh_cmd "$user" || true
            return 0
        fi
        [[ "$d" == "/" ]] && break
        d=$(dirname "$d")
    done
}

# ---------- shell-init ----------

cmd_shell_init() {
    cat <<'EOF'
# ssh-agent-op shell hook. Source via: eval "$(ssh-agent-op shell-init)"
_ssh_agent_op_chpwd() {
    command -v ssh-agent-op >/dev/null 2>&1 || return 0
    if git rev-parse --show-toplevel >/dev/null 2>&1; then
        # Inside a git repo: per-repo `core.sshCommand` (set by `apply`)
        # owns the SSH key choice. Clear any parent-dir env var so it
        # can't override.
        unset GIT_SSH_COMMAND
        ssh-agent-op apply --if-needed --quiet 2>/dev/null || true
    else
        # Outside any repo: if a pinned ancestor matches the cwd, export
        # GIT_SSH_COMMAND so plain `git clone` uses the right key.
        local _ssh_agent_op_cmd
        _ssh_agent_op_cmd=$(ssh-agent-op resolve 2>/dev/null || true)
        if [ -n "$_ssh_agent_op_cmd" ]; then
            export GIT_SSH_COMMAND="$_ssh_agent_op_cmd"
        else
            unset GIT_SSH_COMMAND
        fi
        unset _ssh_agent_op_cmd
    fi
}
if [ -n "${ZSH_VERSION-}" ]; then
    autoload -U add-zsh-hook
    add-zsh-hook chpwd _ssh_agent_op_chpwd
    _ssh_agent_op_chpwd
elif [ -n "${BASH_VERSION-}" ]; then
    case "${PROMPT_COMMAND:-}" in
        *_ssh_agent_op_chpwd*) ;;
        *) PROMPT_COMMAND="_ssh_agent_op_chpwd${PROMPT_COMMAND:+;$PROMPT_COMMAND}" ;;
    esac
fi
EOF
}

# ---------- dispatch ----------

main() {
    local cmd=${1:-}
    [[ -n "$cmd" ]] || { usage; exit 1; }
    shift
    case $cmd in
        apply)          cmd_apply "$@" ;;
        list)           cmd_list "$@" ;;
        remove)         cmd_remove "$@" ;;
        pin)            cmd_pin "$@" ;;
        unpin)          cmd_unpin "$@" ;;
        pins)           cmd_pins "$@" ;;
        resolve)        cmd_resolve "$@" ;;
        shell-init)     cmd_shell_init "$@" ;;
        -h|--help|help) usage ;;
        *)              err "unknown command: $cmd"; usage; exit 1 ;;
    esac
}

main "$@"
